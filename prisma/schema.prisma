generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  SYSTEM
  PROMOTION
  GAME_START
  GAME_RESULT
  PREDICTION_REMINDER
  SCORE_UPDATE
}

enum GameStatus {
  BEFORE
  LIVE
  RESULT
  CANCEL
}

enum PendingPushStatus {
  PENDING
  SENT
  REJECTED
}

enum PostGameReportStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum PregamePreviewStatus {
  PENDING
  READY
  FAILED
}

model NotificationDispatchState {
  id          String   @id @default(cuid())
  alertKind   String
  teamScope   String
  eventKey    String
  gameExternalId String?
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([alertKind, teamScope, eventKey])
  @@index([gameExternalId, alertKind, createdAt])
  @@index([alertKind, createdAt])
}

model User {
  id                String             @id @default(cuid())
  email             String?            @unique
  name              String?
  favoriteTeam      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lastNotifiedAt    DateTime?
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  nativePushTokens  NativePushToken[]
}

model PushSubscription {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint       String    @unique
  p256dh         String
  auth           String
  expirationTime DateTime?
  enabled        Boolean   @default(true)
  userAgent      String?
  topics         Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastSeenAt     DateTime?

  @@index([userId])
  @@index([enabled, userId])
}

/**
 * Capacitor 네이티브 앱의 FCM/APNs 푸시 토큰.
 * Web Push(PushSubscription)와 별개로 관리.
 */
model NativePushToken {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  platform     String   // "ios" | "android"
  enabled      Boolean  @default(true)
  favoriteTeam String?
  topics       Json?
  appEnv       String   @default("production")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastSeenAt   DateTime?

  @@index([userId])
  @@index([enabled, favoriteTeam])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType @default(SYSTEM)
  title       String
  body        String
  deeplinkUrl String?
  imageUrl    String?
  payload     Json?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  sentAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead, createdAt(sort: Desc)])
}

model Game {
  id          String     @id @default(cuid())
  externalId  String     @unique
  homeTeam    String
  awayTeam    String
  homeScore   Int        @default(0)
  awayScore   Int        @default(0)
  status      GameStatus @default(BEFORE)
  isLineupNotified Boolean @default(false)
  gameDate    DateTime?
  startedAt   DateTime?
  endedAt     DateTime?
  highlightNotifiedAt DateTime?
  highlightVideoUrl   String?
  lastHighlightCheckedAt DateTime?
  lastScoreAlertKey String?
  lastScoreAlertAt  DateTime?
  lastSyncedAt DateTime  @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, updatedAt])
  @@index([homeTeam, awayTeam])
}

model PostGameReport {
  id         String               @id @default(cuid())
  externalId String
  teamId     String
  gameDate   DateTime?
  status     PostGameReportStatus @default(PENDING)
  title      String?
  content    String?
  bodyLines  Json?
  facts      Json?
  error      String?
  generatedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([externalId, teamId])
  @@index([teamId, gameDate])
  @@index([status, updatedAt])
}

/**
 * 관리자 승인 대기 중인 푸시 알림.
 * AUTO_CONFIRM_PUSH=false 일 때 sendTeamTopicNotification 호출 시 즉시 발송 대신 여기에 저장.
 * 어드민이 Approve 하면 실 FCM 발송 후 status → SENT.
 */
model PendingPushNotification {
  id        String            @id @default(cuid())
  teamId    String
  topicKey  String
  title     String
  body      String
  url       String
  type      String
  payload   Json?
  status    PendingPushStatus @default(PENDING)
  sentCount Int?
  sentAt    DateTime?
  rejectedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([teamId, createdAt(sort: Desc)])
}

/**
 * 어드민이 수동으로 발송하는 마케팅/QA 푸시.
 * sentCount: 실제 발송된 구독 수, clickCount: 클릭 트래킹 수
 */
model MarketingPush {
  id           String   @id @default(cuid())
  title        String
  body         String
  url          String
  targetTeamId String?
  sentCount    Int      @default(0)
  clickCount   Int      @default(0)
  testOnly     Boolean  @default(false)
  sentAt       DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sentAt(sort: Desc)])
  @@index([targetTeamId, sentAt(sort: Desc)])
}

/**
 * 라이브 이벤트 크론이 게임별로 마지막으로 처리한 릴레이 seqNo 워터마크.
 * 이 seqNo 이하의 엔트리는 재처리하지 않아 중복 알림을 원천 차단.
 */
model LiveEventWatermark {
  id             String   @id @default(cuid())
  gameExternalId String   @unique
  lastSeqNo      Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@index([updatedAt])
}

model PregamePreview {
  id         String               @id @default(cuid())
  date       String
  teamId     String
  gameId     String
  opponentTeamId String
  gameTime   String
  stadium    String?
  status     PregamePreviewStatus @default(PENDING)
  title      String?
  bodyLines  Json?
  context    Json?
  error      String?
  generatedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([date, teamId])
  @@index([date, status])
  @@index([teamId, date])
}
