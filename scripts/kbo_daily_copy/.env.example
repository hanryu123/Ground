# Copy this to .env and fill in values.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 모델 선택. claude-opus-4-6 권장 (카피 품질). 비용 줄이려면 claude-sonnet-4-6.
COPY_MODEL=claude-opus-4-6

# 출력 디렉터리 기본값 (스크립트 인자로 덮어쓰기 가능)
OUTPUT_DIR=./out

# API 실패 시 fallback_copy.json 사용 여부 (true/false)
FALLBACK_ON_ERROR=true
