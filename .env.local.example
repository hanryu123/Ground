# PostgreSQL (Prisma)
# 예: postgresql://USER:PASSWORD@HOST:5432/ground?schema=public
DATABASE_URL=

# Web Push (VAPID)
# 생성: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# Cron 보안 키
# - 권장: Authorization: Bearer <CRON_SECRET>
# - 외부 스케줄러용 대안: /api/cron/check-lineup?secret=<CRON_SECRET>
CRON_SECRET=

# Admin dashboard query guard key
# /admin/dashboard?key=<ADMIN_SECRET>
ADMIN_SECRET=

# 어드민 테스트 푸시 발송 대상 이메일
# PushSenderForm의 [내 폰으로 테스트] 버튼이 이 이메일로 등록된 구독자에게만 발송
ADMIN_TEST_EMAIL=janghanr@gmail.com

# 푸시 알림 발송 모드
# - false (기본값): 크론잡이 생성한 알림을 즉시 발송하지 않고 DB에 PENDING 저장.
#   어드민 대시보드(/admin/dashboard)에서 [발송 승인] 버튼으로 수동 발송.
# - true: 승인 없이 즉시 FCM 발송 (테스트 완료 후 활성화).
AUTO_CONFIRM_PUSH=false

# OpenWeather API (https://openweathermap.org/api)
# 구장 위치 기반 현재 날씨 조회 → 우천 시 '수중전 모드' + rainy 화보 활성화에 사용.
# 키 미설정 시에는 항상 맑음(isRainy=false)으로 fallback 처리됩니다.
# 디버그: /today 화면 URL에 ?forceWeather=rain 또는 ?forceWeather=clear 로 강제 오버라이드 가능.
OPENWEATHER_API_KEY=
